{
  "name": "sito-lorenzo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-vue": "^0.8.1",
    "@vueuse/core": "^10.11.1",
    "alova": "^3.3.4",
    "dayjs": "^1.11.13",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-i18n": "^11.1.11",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.12.0",
    "@tsconfig/node20": "^20.1.6",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.10",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.33.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^24.1.3",
    "npm-run-all2": "^6.2.6",
    "prettier": "^3.6.2",
    "sass": "^1.90.0",
    "typescript": "~5.9.2",
    "vite": "^7.1.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.5"
  }
}
