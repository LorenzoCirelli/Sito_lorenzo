---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainImageLanding from "../../assets/images/landing/lorenzo.png";
---

<style lang="scss">
  @use "../../assets/styling/variables/_spacing" as spacing;
  @use "../../assets/styling/variables/_colors" as color;
  .parent {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(1, 1fr);
    min-height: 100%;
    &__image {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: spacing.$padding * 2;
      align-items: flex-end;
      &--optimizedImage {
        width: 55%;
        height: auto;
        min-width: 300px;
        -webkit-filter: drop-shadow(5px 2px 3px #00000059);
        filter: drop-shadow(5px 2px 3px #00000059);
      }
    }
    &__hero {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;

      &__container {
        display: flex;
        flex-direction: column;
        gap: spacing.$padding * 2;

        background: #ffffff;
        background: radial-gradient(
          circle,
          rgba(255, 255, 255, 1) 0%,
          rgba(255, 255, 255, 1) 78%,
          rgba(255, 255, 255, 0) 100%
        );

        &--welcome {
          display: flex;
          flex-direction: column;
          flex-wrap: wrap;
          strong {
            color: color.$subtext;
          }
        }
      }
    }
  }

  @media only screen and (max-width: 820px) {
    .parent {
      grid-template-columns: repeat(1, 1fr);
      grid-template-rows: repeat(2, 0.3fr);
      &__image {
        margin-left: spacing.$padding * 2;
        margin-bottom: spacing.$padding;
        align-items: center;
        &--optimizedImage {
          width: 90%;
          height: auto;
          min-width: 100px;
        }
      }
    }
  }
</style>
<BaseLayout>
  <div class="parent">
    <div class="parent__image">
      <Image
        src={MainImageLanding}
        alt=""
        class="parent__image--optimizedImage"
        decoding="async"
        loading="lazy"
        width={600}
      />
    </div>
    <div class="parent__hero">
      <div class="parent__hero__container">
        <span class="parent__hero__container--welcome">
          <header>Lorenzo Cirelli Online</header>
          <strong
            >La piattaforma per: scoprire di me, leggere i miei articoli,
            conoscere le mie librerie e software open source</strong
          >
        </span>
        <span class="parent__hero__container--cta">
          <figcaption>
            Cliccando iniziamo seguirai una procedura di onboarding
          </figcaption>
          <a href="it/onboarding"><button>Iniziamo</button></a>
        </span>
      </div>
    </div>
  </div>
</BaseLayout>
<script>
  import { gsap } from "gsap";

  gsap.to(".parent", {
    keyframes: {
      x: [0, 0, 0],
      y: [50, 40, 0],
      easeEach: "sine.inOut",
      ease: "expo.out",
    },
    duration: 2,
  });
</script>
